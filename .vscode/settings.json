{
    "python.analysis.extraPaths": [
        "${workspaceFolder}",
        "${workspaceFolder}/../fastsdk",
        "${workspaceFolder}/../fastCloud",
        "${workspaceFolder}/../media-toolkit",
        "${workspaceFolder}/../meseex",
        "${workspaceFolder}/../APIPodRegistry",
        "${workspaceFolder}/../socaity_schemas"
    ],
    "python.analysis.autoImportCompletions": true,
    "python.analysis.indexing": true,
    "python.analysis.packageIndexDepths": [
        {
            "name": "fastsdk",
            "depth": 5
        },
        {
            "name": "fastcloud",
            "depth": 5
        },
        {
            "name": "media_toolkit",
            "depth": 5
        },
        {
            "name": "meseex",
            "depth": 5
        }, 
        {
            "name": "apipod_registry",
            "depth": 5
        },
        {
            "name": "socaity_schemas",
            "depth": 5
        }
    ],
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.autoSearchPaths": true,
    "ruff.lineLength": 120,
    "ruff.lint.ignore": [
        "E203",
        "W503",
        "E501",
        "W293",
        "W291"
    ]
} 